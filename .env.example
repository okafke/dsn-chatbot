# ===========================================
# DSN Chatbot - Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values

# --- Database ---
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=change-me-to-a-secure-password
POSTGRES_DB=chatbot

# --- JWT Authentication ---
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-to-a-random-secret

# --- LLM Provider ---
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
# Comma-separated list of models available for user selection (defaults to OPENAI_MODEL if empty)
#AVAILABLE_MODELS=gpt-4o,gpt-4o-mini

# --- Application ---
APP_ENV=production

# CORS_ORIGINS: Comma-separated list of allowed origins.
# - For local/no-domain use: http://localhost or http://YOUR_SERVER_IP
# - For domain use: https://chat.example.com
CORS_ORIGINS=http://localhost

# APP_DOMAIN: Only needed if you have a domain and want HTTPS.
# Leave commented out if you're running without a domain.
# APP_DOMAIN=chat.example.com
