# Application
APP_ENV=development
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://chatbot:chatbot@db:5432/chatbot

# JWT Auth
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM Provider
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
# Comma-separated list of models available for user selection (defaults to OPENAI_MODEL if empty)
AVAILABLE_MODELS=gpt-4o,gpt-4o-mini

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
